# Development container for hydraulic-analysis.
# Separate from streamlit_app/Dockerfile, which builds the production
# Streamlit dashboard image — this one is for day-to-day development in
# VS Code (linting, testing, notebooks), per the project's Tech & CI/CD spec.
FROM python:3.10-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

# Install project + dev dependencies at image-build time so the container
# starts ready to use (lint, test, run notebooks) without a slow
# postCreateCommand step.
COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -r requirements.txt \
    && pip install --no-cache-dir ruff jupyter ipykernel

CMD ["sleep", "infinity"]
